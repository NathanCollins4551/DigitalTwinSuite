{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=digital_twin_local;Username=postgres;Password=postgres"
  },
  "BambuProxy": {
    "BaseUrl": "http://localhost:5001",
    "ApiToken": "mock-token"
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "localhost:6379"
  },
  "InfluxDb": {
    "Enabled": false,
    "Url": "http://localhost:8086",
    "Token": "mock-token",
    "Org": "myorg",
    "Bucket": "twin_bucket"
  },
  "Telemetry": {
    "WorkerTickSeconds": 1,
    "LookbackMinutesDefault": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Workers": {
    "EnablePrinterCatalogSyncWorker": false,
    "EnablePrintSchedulingWorker": false,
    "EnablePrinterSimulationManagerWorker": true,
    "EnableCvEventsConsumerWorker": true
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "twin",
    "Password": "twinrabbitpass"
  }
}